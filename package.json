    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^3.0.3",
    "next": "16.1.6",
    "nodemailer": "^8.0.2",
    "openai": "^6.27.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
