{
  "name": "ai-meditation-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test lib/__tests__/entitlements.test.ts lib/__tests__/guest-limit.test.ts lib/__tests__/signup-consent.test.ts lib/__tests__/static-regression.test.ts lib/__tests__/admin-billing.test.ts",
