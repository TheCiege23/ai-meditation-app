# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Runtime/cache data — never commit DB or generated audio
data/cache.db
data/cache.db-shm
data/cache.db-wal
data/cache.sqlite
data/audio-cache/
data/generated/
data/tmp/
# data/seo/ is application source code — keep it tracked

# Claude project memory (local AI notes, not source code)
/memory/

# local dev log files
.tmp-*.log

# test artifacts
/playwright-report/
/test-results/
